@* Index.cshtml - Landing page *@
@{
    ViewData["Title"] = "Home";
}
<div class="hero d-flex align-items-center justify-content-center text-center min-vh-100" style="background: linear-gradient(135deg, #6a11cb, #2575fc);">
    <div class="text-white">
        <h1 class="display-4 fw-bold mb-3 animate-fade-in-up">Welcome to Loan Origination</h1>
        <p class="lead mb-4 animate-fade-in-up" style="animation-delay: 0.2s;">Apply for loans, track status, and manage documents – all in one place.</p>
        <a href="@Url.Action("Login", "Account")" class="btn btn-light btn-lg animate-fade-in-up" style="animation-delay: 0.4s;">Sign In</a>
    </div>
</div>
